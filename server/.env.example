# CampusLens API — copy to .env and fill in. Never commit the real .env.

# MongoDB Atlas connection string
MONGO_URI=

# Google Gemini (embeddings + generation)
GEMINI_API_KEY=

# Pinecone vector store
PINECONE_API_KEY=
PINECONE_INDEX=

# Comma-separated list of allowed frontend origins for CORS in production.
# Leave blank for local dev (the client uses the same-origin Vite proxy).
# Example: CORS_ORIGIN=https://campuslens.vercel.app
CORS_ORIGIN=

# Port the API listens on. Hosts (Render) set this automatically; 3000 locally.
PORT=3000

# Max PDF upload size in megabytes (optional; defaults to 15).
MAX_UPLOAD_MB=15

# Retrieval tuning (optional; sensible defaults live in code).
# SOURCE_SCORE_THRESHOLD=0.55
# MIN_CONTEXT_SCORE=0.55
